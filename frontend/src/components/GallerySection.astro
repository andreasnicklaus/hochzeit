---
import { Image } from "astro:assets";
import img01 from "../assets/images/location/hochzeit-portal-10.jpg";
import img02 from "../assets/images/location/schloss-filseck-panorama.jpg";
import img03 from "../assets/images/location/schloss-filseck-005.jpg";
import img04 from "../assets/images/location/schloss-filseck-exterior.jpg";
import img05 from "../assets/images/couple/couple_sundown.jpeg";
import img06 from "../assets/images/location/hochzeit-portal-01.jpg";
import img07 from "../assets/images/location/hochzeit-portal-03.jpg";
import img08 from "../assets/images/couple/couple_artsy.jpeg";
import img09 from "../assets/images/location/hochzeit-portal-09.jpg";
import img10 from "../assets/images/location/hochzeit-portal-11.jpg";
import img11 from "../assets/images/location/schloss-filseck-courtyard.jpg";
import img12 from "../assets/images/location/schloss-filseck-garden.jpg";
import img13 from "../assets/images/location/hochzeit-portal-12.jpg";

const photos = [
  { src: img01, alt: "Schloss Filseck Innenraum", span: "", caption: "Außenansicht" },
  { src: img02, alt: "Schloss Filseck Panoramablick", span: "", caption: "Panoramablick" },
  { src: img03, alt: "Schloss Filseck Außenansicht", span: "", caption: "Arkadenhof" },
  { src: img04, alt: "Schloss Filseck Frontansicht", span: "", caption: "Frontansicht" },
  { src: img05, alt: "Andreas & Anna-Lena", span: "", caption: "Andreas & Anna-Lena" },
  { src: img06, alt: "Schloss Filseck Innenraum", span: "", caption: "Restaurant" },
  { src: img07, alt: "Schloss Filseck Innenraum", span: "", caption: "Restaurant 2" },
  { src: img08, alt: "Andreas & Anna-Lena", span: "", caption: "Andreas & Anna-Lena" },
  { src: img09, alt: "Schloss Filseck Außenbereich", span: "", caption: "Arkadenhof 2" },
  { src: img10, alt: "Innenhof", span: "", caption: "Arkadenhof 3" },
  { src: img11, alt: "Schloss Filseck Arkadenhof", span: "", caption: "Arkadenhof 4" },
  { src: img12, alt: "Schloss Filseck Schlossgarten", span: "", caption: "Schlossgarten" },
  { src: img13, alt: "Schloss Filseck Außenansicht", span: "", caption: "Außenansicht 2" },
];
---

<section id="gallery" class="py-24 px-6 bg-white">
  <div class="max-w-2xl mx-auto text-center">
    <p
      class="text-sm uppercase tracking-[0.3em] text-stone-400 mb-6 font-body font-light"
    >
      Galerie
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-semibold text-stone-800">
      Impressionen
    </h2>
  </div>

  <div
    class="max-w-5xl mx-auto mt-12 grid grid-cols-1 md:grid-cols-3 gap-4 auto-rows-[250px]"
  >
    {
      photos.map((photo) => (
        <button
          class="gallery-btn group relative overflow-hidden rounded-lg bg-stone-100 shadow-sm cursor-pointer {photo.span}"
          data-src={photo.src.src}
          data-alt={photo.alt}
        >
          <Image
            src={photo.src}
            alt={photo.alt}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-all duration-300" />
          <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <span class="text-white text-xs font-medium">{photo.caption}</span>
          </div>
        </button>
      ))
    }
  </div>
</section>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 bg-black/80 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300"
>
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 text-white/70 hover:text-white text-3xl leading-none cursor-pointer z-10"
    >&times;</button
  >
  <button
    id="lightbox-prev"
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-4xl leading-none cursor-pointer z-10 hidden"
    >&lsaquo;</button
  >
  <button
    id="lightbox-next"
    class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-4xl leading-none cursor-pointer z-10 hidden"
    >&rsaquo;</button
  >
  <img
    id="lightbox-img"
    class="max-w-full max-h-[90vh] object-contain rounded-lg shadow-2xl"
    src=""
    alt=""
  />
</div>

<style>
  .gallery-btn:last-child {
    grid-column: 2;
  }
</style>

<script>
  const images = document.querySelectorAll(".gallery-btn");
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img");
  const lightboxClose = document.getElementById("lightbox-close");
  const lightboxPrev = document.getElementById("lightbox-prev");
  const lightboxNext = document.getElementById("lightbox-next");

  const imageData = Array.from(document.querySelectorAll(".gallery-btn")).map(
    (btn) => ({
      src: btn.dataset.src,
      alt: btn.dataset.alt,
    }),
  );

  let currentIdx = 0;

  function openLightbox(index) {
    currentIdx = index;
    lightboxImg.src = imageData[index].src;
    lightboxImg.alt = imageData[index].alt;
    lightbox.classList.remove("opacity-0", "pointer-events-none");
    document.body.style.overflow = "hidden";
    lightboxPrev.style.display = imageData.length > 1 ? "block" : "none";
    lightboxNext.style.display = imageData.length > 1 ? "block" : "none";
  }

  function closeLightbox() {
    lightbox.classList.add("opacity-0", "pointer-events-none");
    document.body.style.overflow = "";
  }

  function prevImage() {
    if (imageData.length > 1) {
      currentIdx = (currentIdx - 1 + imageData.length) % imageData.length;
      lightboxImg.src = imageData[currentIdx].src;
      lightboxImg.alt = imageData[currentIdx].alt;
    }
  }

  function nextImage() {
    if (imageData.length > 1) {
      currentIdx = (currentIdx + 1) % imageData.length;
      lightboxImg.src = imageData[currentIdx].src;
      lightboxImg.alt = imageData[currentIdx].alt;
    }
  }

  images.forEach((btn, i) => {
    btn.addEventListener("click", () => openLightbox(i));
  });

  lightboxClose.addEventListener("click", closeLightbox);
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  lightboxPrev.addEventListener("click", prevImage);
  lightboxNext.addEventListener("click", nextImage);

  document.addEventListener("keydown", (e) => {
    if (!lightbox.classList.contains("opacity-0")) {
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") prevImage();
      if (e.key === "ArrowRight") nextImage();
    }
  });
</script>
