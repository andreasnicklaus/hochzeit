---
const events = [
  {
    time: "ab 15:00",
    title: "Ankommen",
    desc: "Kommt an, findet eure Platze und genießt die Vorfreude.",
  },
  {
    time: "15:30 - 16:00",
    title: "Trauung",
    desc: "Standesamtliche Trauung auf Schloss Filseck.",
  },
  {
    time: "ab 16:00",
    title: "Sektempfang",
    desc: "Anstoßen und feiern im Arkadenhof.",
  },
  {
    time: "abends",
    title: "Abendessen",
    desc: "Gemeinsames Abendessen.",
  },
  {
    time: "open end",
    title: "Party & Tanz",
    desc: "Tanzt mit uns bis in die Nacht!",
  },
];
---

<section class="py-24 px-6 bg-paper" id="timeline">
  <div class="max-w-2xl mx-auto text-center" data-animate="fade-up">
    <p class="text-sm uppercase tracking-[0.3em] text-stone-400 mb-6 font-body font-light">
      12. Juni 2027
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-semibold text-stone-800">
      Unser Tag
    </h2>
  </div>

  <div class="relative max-w-2xl mx-auto mt-16">
    <div class="absolute left-5 md:left-1/2 top-0 bottom-0 w-px bg-beige md:-translate-x-1/2" />

    <div class="space-y-12">
      {
        events.map((event, i) => (
          <div class="relative grid grid-cols-[40px_1fr] md:grid-cols-[1fr_40px_1fr] gap-x-4 md:gap-x-8 items-start" data-animate="fade-up">
            <div class="hidden md:block text-right pt-1">
              <span class="font-display text-lg text-terracotta whitespace-nowrap">
                {event.time}
              </span>
            </div>

            <div class="flex justify-center pt-1">
              <div class="w-4 h-4 rounded-full bg-terracotta border-2 border-white shadow-sm shrink-0" />
            </div>

            <div>
              <span class="font-display text-base text-terracotta md:hidden block">
                {event.time}
              </span>
              <h3 class="font-display text-xl font-semibold text-stone-800 mt-0.5">
                {event.title}
              </h3>
              <p class="text-stone-500 font-body font-light mt-1 text-sm leading-relaxed">
                {event.desc}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
