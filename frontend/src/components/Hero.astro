---
const names = ['Andreas', 'Anna-Lena'];
const date = '12. Juni 2027 | 15:30 Uhr';
const location = 'Schloss Filseck, Uhingen';
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col bg-stone-900"
  style="background-image: url(/images/location/schloss-filseck-courtyard.jpg); background-size: cover; background-position: center 30%;"
>
  <div class="relative z-10 flex-1 flex flex-col items-center justify-center px-6 text-center">
    <div class="w-full max-w-lg md:max-w-xl lg:max-w-2xl bg-paper/50 backdrop-blur-xl rounded-2xl px-10 py-14 shadow-xl border border-white/10">
      <p class="text-sm uppercase tracking-[0.3em] text-stone-700 mb-6 font-body font-light">
        Wir heiraten
      </p>

      <h1 class="font-display text-5xl md:text-7xl leading-tight font-semibold text-stone-900">
        {names[0]} & {names[1]}
      </h1>

      <div class="w-12 h-px bg-terracotta mx-auto my-8" />

      <p class="text-lg md:text-xl font-display italic text-stone-700">
        {date}
      </p>

      <p class="text-sm text-stone-600 mt-1 font-body font-light">
        {location}
      </p>

      <p class="mt-10 text-stone-700 font-body font-light leading-relaxed max-w-md mx-auto">
        Wir freuen uns, diesen Tag mit euch zu feiern.<br />
        Bitte gebt uns bis zum <span class="font-semibold text-stone-900">1. Mai 2027</span> Bescheid,
        ob ihr dabei seid.
      </p>

      <button
        id="rsvp-button"
        class="mt-10 bg-terracotta hover:bg-terracotta/90 text-white px-10 py-3.5 rounded-full text-sm font-medium tracking-wide transition-all duration-300 shadow-sm hover:shadow-md"
      >
        Jetzt antworten
      </button>
    </div>
  </div>

  <div class="relative z-10 flex justify-center pb-8">
    <div class="animate-bounce">
      <svg class="w-6 h-6 text-white/70 drop-shadow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<section class="relative min-h-screen flex flex-col bg-paper">
  <div class="flex-1 flex flex-col items-center justify-center px-6 text-center">
    <div class="max-w-xl">
      <p class="text-sm uppercase tracking-[0.3em] text-stone-400 mb-6 font-body font-light">
        Wir heiraten
      </p>

      <h1 class="font-display text-5xl md:text-7xl leading-tight font-semibold text-stone-800">
        <span class="text-terracotta">{names[0]}</span> <span class="text-terracotta">&</span> <span class="text-terracotta">{names[1]}</span>
      </h1>

      <div class="w-12 h-px bg-terracotta mx-auto my-8" />

      <p class="text-lg md:text-xl font-display italic text-stone-500">
        {date}
      </p>

      <p class="text-sm text-stone-400 mt-1 font-body font-light">
        {location}
      </p>

      <p class="mt-10 text-stone-500 font-body font-light leading-relaxed max-w-md mx-auto">
        Wir freuen uns, diesen Tag mit euch zu feiern.<br />
        Bitte gebt uns bis zum <span class="font-medium text-stone-700">1. Mai 2027</span> Bescheid,
        ob ihr dabei seid.
      </p>

      <button
        data-rsvp
        class="mt-10 bg-terracotta hover:bg-terracotta/90 text-white px-10 py-3.5 rounded-full text-sm font-medium tracking-wide transition-all duration-300 shadow-sm hover:shadow-md"
      >
        Jetzt antworten
      </button>
    </div>
  </div>

  <div class="flex justify-center pb-8">
    <div class="animate-bounce">
      <svg class="w-6 h-6 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-rsvp], #rsvp-button').forEach((btn) => {
    btn?.addEventListener('click', () => {
      const event = new CustomEvent('open-rsvp');
      document.dispatchEvent(event);
    });
  });
</script>
