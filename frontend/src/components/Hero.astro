---
const names = ["Anna-Lena", "Andreas"];
const date = "12. Juni 2027 | 15:30 Uhr";
const location = "Schloss Filseck, Uhingen";
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col bg-stone-900"
  style="background-image: url(/images/location/schloss-filseck-courtyard.jpg); background-size: cover; background-position: center 30%;"
>
  <div
    class="relative z-10 flex-1 flex flex-col items-center justify-center px-6 text-center"
  >
    <div
      class="w-full max-w-lg md:max-w-xl lg:max-w-2xl bg-paper/80 backdrop-blur-xl rounded-2xl px-10 py-14 shadow-xl border border-white/10"
    >
      <p
        class="text-sm uppercase tracking-[0.3em] text-stone-700 mb-6 font-body font-light"
      >
        Wir heiraten!
      </p>

      <h1
        class="font-display text-5xl md:text-7xl leading-tight font-semibold text-stone-800 text-terracotta"
      >
        {names[0]} & {names[1]}
      </h1>

      <div class="w-12 h-px bg-terracotta mx-auto my-8"></div>

      <p class="text-lg md:text-xl font-display italic text-stone-700">
        {date}
      </p>

      <p class="text-sm text-stone-600 mt-1 font-body font-light">
        {location}
      </p>

      <p
        class="mt-10 text-stone-700 font-body font-light leading-relaxed max-w-md mx-auto"
      >
        Wir freuen uns, diesen Tag mit euch zu feiern!
      </p>

      <div class="mt-6">
        <button
          id="rsvp-button"
          class="bg-terracotta hover:bg-terracotta/90 text-white px-10 py-3.5 rounded-full text-sm font-medium tracking-wide transition-all duration-300 shadow-sm hover:shadow-md inline-flex flex-col items-center leading-tight"
        >
          <span class="text-[14px]">Jetzt antworten</span>
          <span class="text-[10px] mt-1 opacity-90 font-light"
            >bis 1. Mai 2027</span
          >
        </button>
      </div>
    </div>
  </div>

  <div class="relative z-10 flex justify-center pb-8">
    <a href="#location" aria-label="Nach unten scrollen" class="group">
      <div
        class="animate-bounce flex h-11 w-11 items-center justify-center rounded-full bg-white/90 text-stone-600 shadow-lg ring-1 ring-white/60 transition-transform duration-300 group-hover:scale-105"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 5v14m0 0l-7-7m7 7l7-7"></path>
        </svg>
      </div>
    </a>
  </div>
</section>

<script>
  document.querySelectorAll("[data-rsvp], #rsvp-button").forEach((btn) => {
    btn?.addEventListener("click", () => {
      const event = new CustomEvent("open-rsvp");
      document.dispatchEvent(event);
    });
  });
</script>
