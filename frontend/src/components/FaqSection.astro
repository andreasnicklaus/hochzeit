---
const faqs = [
  {
    q: "Wann sollte ich ankommen?",
    a: "Bitte seid bis 15:15 Uhr auf Schloss Filseck, damit wir pünktlich um 15:30 mit der Trauung starten können.",
  },
  {
    q: "Kann ich ein Plus-One mitbringen?",
    a: "Wenn auf deiner Einladung ein Plus-One vermerkt ist, darfst du gern eine Begleitung mitbringen. Sag uns bei der RSVP einfach Bescheid, wen du mitbringst, damit wir alles planen konnen.",
  },
  {
    q: "Sind Kinder willkommen?",
    a: "Wenn sie auf der Einladung stehen, sind sie herzlich willkommen. Bitte gebt sie beim RSVP mit an. Es wird keine eigene Unterhaltung fur die Kinder geben, aber direkt neben der Location gibt es einen Spielplatz und der Schloßgarten ist eingezäunt und gut fur Kinder geeignet.",
  },
  {
    q: "Darf ich während der Trauung fotografieren?",
    a: "Wir haben einen Fotografen - deshalb bitten wir euch, die Kameras während der Zeremonie wegzulassen. Danach dürft ihr gerne knipsen!",
  },
  {
    q: "Wo kann ich parken?",
    a: "Parkplätze sind direkt am Schloss Filseck vorhanden.",
  },
  {
    q: "Bis wann muss ich antworten?",
    a: "Bitte bis zum 1. Mai 2027 über das Formular auf dieser Seite.",
  },
  {
    q: "Ich habe eine Lebensmittelunverträglichkeit oder Allergie.",
    a: "Bitte beim RSVP im Feld Essenswunsch angeben - wir kümmern uns darum.",
  },
  {
    q: "Kann ich Fotos von der Hochzeit in Social Media posten?",
    a: "Gerne, aber bitte erst nachdem wir selbst unsere ersten Fotos geteilt haben!",
  },
  {
    q: "Gibt es Übernachtungsmöglichkeiten in der Nähe?",
    a: 'Ja - schaut dazu gern in unsere <a href="#unterkuenfte" class="underline underline-offset-2 decoration-sage/50 hover:decoration-sage transition-colors">Unterkunfts-Sektion</a> weiter unten auf dieser Seite.',
  },
];
---

<section class="py-24 px-6 bg-white" id="faq">
  <div class="max-w-2xl mx-auto">
    <div class="text-center" data-animate="fade-up">
      <p class="text-sm uppercase tracking-[0.3em] text-stone-400 mb-6 font-body font-light">
        Info
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-stone-800">
        Wichtige Fragen
      </h2>
    </div>

    <div class="mt-6 rounded-xl border border-[#E8DED1] bg-paper p-6 sm:p-8 text-center" data-animate="fade-up">
      <p class="text-xs uppercase tracking-[0.2em] text-sage font-medium mb-2">Dresscode</p>
      <p class="font-display text-xl text-stone-800 font-semibold">
        Sommerliche Festkleidung
      </p>
      <p class="text-stone-500 font-body font-light mt-2 text-sm leading-relaxed max-w-md mx-auto">
        Tragt gerne Farben und leichte Stoffe! Es ist Juni und wir feiern drinnen wie draußen -<br />
        eher Sommerparty als steife Hochzeit.
      </p>
    </div>

    <div class="mt-10 space-y-3" data-animate="fade-up">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-beige bg-white transition-colors open:border-terracotta/30 open:bg-terracotta/5">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-sm font-medium text-stone-700 list-none transition-colors group-open:text-terracotta">
              {faq.q}
              <svg
                class="w-4 h-4 text-stone-400 shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-stone-500 font-body font-light leading-relaxed" set:html={faq.a}></div>
          </details>
        ))
      }
    </div>
  </div>
</section>